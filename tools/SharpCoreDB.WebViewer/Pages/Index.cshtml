@page
@model SharpCoreDB.WebViewer.Pages.IndexModel
@{
    ViewData["Title"] = "Query";
}

@section Toolbar {
    @if (Model.IsConnected)
    {
        <button type="button" class="scdb-toolbar__btn scdb-toolbar__btn--primary"
                id="btn-execute" title="Execute (F5)" data-action="execute-query">
            ▶ Execute
        </button>
        <div class="scdb-toolbar__separator"></div>
        <form method="post" asp-page-handler="Disconnect" class="scdb-form-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="scdb-toolbar__btn" title="Disconnect from current database">
                ⏹ Disconnect
            </button>
        </form>
        <div class="scdb-toolbar__separator"></div>

        @if (!Model.IsTransactionActive)
        {
            <form method="post" asp-page-handler="BeginTransaction" class="scdb-form-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="scdb-toolbar__btn" title="Begin transaction">Begin TXN</button>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="CommitTransaction" class="scdb-form-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="scdb-toolbar__btn" title="Commit transaction">✓ Commit</button>
            </form>
            <form method="post" asp-page-handler="RollbackTransaction" class="scdb-form-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="scdb-toolbar__btn scdb-toolbar__btn--danger" title="Rollback transaction">✕ Rollback</button>
            </form>
        }
    }
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div id="scdb-alert-error" class="scdb-alert scdb-alert--error scdb-alert--overlay">
        <span>⚠</span>
        <span>@Model.ErrorMessage</span>
        <button type="button" data-action="dismiss-alert" class="scdb-alert__close" aria-label="Dismiss">✕</button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div id="scdb-alert-status" class="scdb-alert scdb-alert--success scdb-alert--overlay">
        <span>✓</span>
        <span>@Model.StatusMessage</span>
        <button type="button" data-action="dismiss-alert" class="scdb-alert__close" aria-label="Dismiss">✕</button>
    </div>
}

<aside class="scdb-sidebar" id="scdb-object-explorer" aria-label="Object Explorer">
    <div class="scdb-sidebar__header">
        Object Explorer
        @if (Model.IsConnected)
        {
            <span class="scdb-float-right scdb-font-normal scdb-truncate-text">
                @Model.ActiveTargetDisplay
            </span>
        }
    </div>

    <div class="scdb-sidebar__body">
        <div class="scdb-sidebar__group">
            <button type="button" class="scdb-sidebar__group-header" data-action="toggle-group" aria-expanded="true">
                <span class="scdb-sidebar__chevron">▾</span>
                Connections
            </button>
            <ul class="scdb-sidebar__tree">
                @if (!Model.IsConnected)
                {
                    <li title="No active connection"><span class="scdb-muted">No active connection</span></li>
                }
                else
                {
                    <li class="selected" title="@Model.ActiveTargetDisplay">
                        <span class="scdb-truncate">@Model.ActiveSession?.Name</span>
                    </li>
                }
            </ul>
        </div>

        @if (!Model.IsConnected)
        {
            <p class="scdb-p-12 scdb-text-muted scdb-text-12">
                Connect to a database to browse objects.
            </p>
            <div class="scdb-sidebar__actions">
                <button type="button" class="scdb-btn scdb-btn--secondary scdb-sidebar__action" data-action="open-create-db">+ New Database</button>
            </div>
        }
        else if (Model.Tables.Count == 0)
        {
            <p class="scdb-p-12 scdb-text-muted scdb-text-12">No tables found.</p>
        }
        else
        {
            <div class="scdb-sidebar__group">
                <button type="button" class="scdb-sidebar__group-header" data-action="toggle-group" aria-expanded="true">
                    <span class="scdb-sidebar__chevron">▾</span>
                    Databases
                </button>
                <ul class="scdb-sidebar__tree">
                    <li class="selected" title="@Model.ActiveTargetDisplay">
                        <span class="scdb-truncate">@Model.ActiveTargetDisplay</span>
                    </li>
                </ul>

                <button type="button" class="scdb-sidebar__group-header" data-action="toggle-group" aria-expanded="true">
                    <span class="scdb-sidebar__chevron">▾</span>
                    Tables
                    <span class="scdb-muted scdb-text-xs scdb-ml-4">(@Model.Tables.Count)</span>
                </button>
                <ul class="scdb-sidebar__tree" id="scdb-table-list">
                    @foreach (var table in Model.Tables)
                    {
                        var isSelected = string.Equals(table, Model.SelectedTable, StringComparison.OrdinalIgnoreCase);
                        <li class="@(isSelected ? "selected" : "")"
                            data-table="@table"
                            role="option"
                            tabindex="0"
                            aria-selected="@isSelected.ToString().ToLower()"
                            data-action="select-table"
                            title="@table">
                            <svg class="scdb-sidebar__tree-icon" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                                <rect x="1" y="2" width="12" height="10" rx="1" stroke="#4ec9b0" stroke-width="1.1"/>
                                <line x1="1" y1="5" x2="13" y2="5" stroke="#4ec9b0" stroke-width="1.1"/>
                                <line x1="4" y1="2" x2="4" y2="12" stroke="#4ec9b0" stroke-width="1.1"/>
                            </svg>
                            <span class="scdb-truncate">@table</span>
                        </li>
                    }
                </ul>

                <div class="scdb-sidebar__actions" id="scdb-table-actions">
                    <button type="button" class="scdb-btn scdb-btn--secondary scdb-sidebar__action" data-action="new-query-selection">New Query</button>
                    <button type="button" class="scdb-btn scdb-btn--secondary scdb-sidebar__action" data-action="select-top-selection">Select Top 100</button>
                    <button type="button" class="scdb-btn scdb-btn--secondary scdb-sidebar__action" data-action="count-rows-selection">Count Rows</button>
                </div>
            </div>
        }
    </div>

    @if (Model.SelectedTableMetadata is not null)
    {
        <div class="scdb-sidebar__meta" id="scdb-table-meta">
            <div class="scdb-sidebar__meta-header">@Model.SelectedTableMetadata.Name</div>
            <table class="scdb-sidebar__meta-table">
                <thead>
                    <tr>
                        <th>Column</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in Model.SelectedTableMetadata.Columns)
                    {
                        <tr>
                            <td class="scdb-mono scdb-truncate" title="@col.Name">@col.Name</td>
                            <td class="scdb-mono scdb-muted">@col.DataType</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</aside>

<div class="scdb-splitter scdb-splitter--vertical" id="scdb-splitter-left" role="separator" aria-label="Resize object explorer" aria-orientation="vertical"></div>

<div class="scdb-workspace" id="scdb-workspace" data-tab-scope="@Model.ActiveTargetKey">
    <div class="scdb-editor-panel" id="scdb-editor-panel">
        <div class="scdb-editor-panel__toolbar">
            <span class="scdb-editor-panel__label">SQL Query</span>

            @if (Model.IsConnected)
            {
                <button type="button" class="scdb-toolbar__btn scdb-toolbar__btn--primary"
                        id="btn-execute-inner" title="Execute query (F5)" data-action="execute-query">▶ Execute</button>

                <div class="scdb-toolbar__separator"></div>

                <form method="post" asp-page-handler="PreviewTable" class="scdb-form-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SelectedTable" />
                    <button type="submit" class="scdb-toolbar__btn" title="SELECT * FROM selected table">
                        Preview
                    </button>
                </form>
            }

            <div class="scdb-editor-panel__toolbar-end">
                <button type="button" class="scdb-toolbar__btn" id="scdb-open-command-palette" data-action="open-command-palette" title="Command palette (Ctrl+Shift+P)">
                    ⌘ Commands
                </button>
                <span id="scdb-sql-validation-msg" class="scdb-validation-message scdb-hidden"></span>
                <span class="scdb-shortcut-hint" title="Keyboard shortcut">F5 / Ctrl+Enter / Ctrl+T</span>
            </div>
        </div>

        <div class="scdb-query-tabs" id="scdb-query-tabs" role="tablist" aria-label="SQL windows"></div>

        <form method="post" asp-page-handler="ExecuteQuery" id="form-execute-main">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SelectedTable" />
            <input type="hidden" id="ActiveQueryTabId" name="ActiveQueryTabId" value="" />
            <input type="hidden" id="QueryTabsStateJson" name="QueryTabsStateJson" value="" />
            <textarea class="scdb-editor-textarea"
                      id="scdb-sql-editor"
                      name="Query.Sql"
                      asp-for="Query.Sql"
                      rows="8"
                      placeholder="-- Enter SQL here, then press F5 or Ctrl+Enter to execute"
                      spellcheck="false"
                      autocomplete="off"
                      autocorrect="off"
                      autocapitalize="off"></textarea>
            <input type="hidden" asp-for="Query.ParametersJson" id="scdb-params-field" />
        </form>
    </div>

    <div class="scdb-results-panel" id="scdb-results-panel">
        <div class="scdb-results-tabs" role="tablist">
            <button class="scdb-results-tab @(Model.HasQueryResult ? "active" : "")"
                    role="tab" id="tab-results"
                    data-action="switch-result-tab" data-tab="results"
                    aria-selected="@Model.HasQueryResult.ToString().ToLower()">
                Results
                @if (Model.QueryResult?.Rows is not null)
                {
                    <span class="scdb-tab-count">(@Model.QueryResult.Rows.Count)</span>
                }
            </button>
            <button class="scdb-results-tab @(!Model.HasQueryResult ? "active" : "")"
                    role="tab" id="tab-messages"
                    data-action="switch-result-tab" data-tab="messages"
                    aria-selected="@(!Model.HasQueryResult).ToString().ToLower()">
                Messages
            </button>
            <div class="scdb-results-actions">
                <button type="button" class="scdb-toolbar__btn" data-action="export-csv" title="Export current result grid as CSV">Export CSV</button>
                <button type="button" class="scdb-toolbar__btn" data-action="export-json" title="Export current result grid as JSON">Export JSON</button>
            </div>
        </div>

        <div class="scdb-results-body" id="pane-results"
             @(Model.HasQueryResult ? "" : "hidden")>
            <div class="scdb-pagination-toolbar" id="scdb-pagination-toolbar"></div>
            @if (Model.QueryResult?.Rows is { Count: > 0 })
            {
                <table class="scdb-grid" aria-label="Query results">
                    <thead>
                        <tr>
                            <th class="scdb-grid__row-num-col">#</th>
                            @foreach (var col in Model.QueryResult.Columns)
                            {
                                <th title="@col">@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @{int rowNum = 1;}
                        @foreach (var row in Model.QueryResult.Rows)
                        {
                            <tr>
                                <td class="scdb-grid__row-num">@rowNum</td>
                                @foreach (var cell in row.Values)
                                {
                                    if (cell is null)
                                    {
                                        <td><span class="scdb-grid__null">NULL</span></td>
                                    }
                                    else
                                    {
                                        <td title="@cell.ToString()">@cell.ToString()</td>
                                    }
                                }
                            </tr>
                            rowNum++;
                        }
                    </tbody>
                </table>
            }
            else if (Model.HasQueryResult)
            {
                <div class="scdb-results-empty">Query executed successfully. No rows returned.</div>
            }
        </div>

        <div class="scdb-results-body" id="pane-messages"
             @(!Model.HasQueryResult ? "" : "hidden")>
            <div class="scdb-messages-body">
                @if (!Model.IsConnected)
                {
                    <p class="scdb-text-muted scdb-text-12">Not connected. Use the Connection panel on the right to connect to a database.</p>
                }
                else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <pre class="scdb-mono scdb-messages-pre scdb-text-error">@Model.ErrorMessage</pre>
                }
                else if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <pre class="scdb-mono scdb-messages-pre scdb-text-ok">@Model.StatusMessage</pre>
                }
                else
                {
                    <p class="scdb-text-muted scdb-text-12">Execute a query to see results.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="scdb-splitter scdb-splitter--vertical" id="scdb-splitter-right" role="separator" aria-label="Resize side tools" aria-orientation="vertical"></div>

<div class="scdb-right-panel" id="scdb-right-panel">
    <div class="scdb-panel-tabs" role="tablist">
        <button class="scdb-panel-tab active" id="ptab-connect"
                data-action="switch-panel" data-panel="connect" role="tab">
            <span>@(Model.IsConnected ? "Session" : "Connect")</span>
            <button type="button" class="scdb-panel-tab__dock-btn" data-action="toggle-panel-dock" data-panel="connect"
                    title="Toggle panel" aria-label="Toggle panel">
                <span class="scdb-sidebar__chevron">▾</span>
            </button>
        </button>
        <button class="scdb-panel-tab" id="ptab-saved"
                data-action="switch-panel" data-panel="saved" role="tab">
            <span>Saved
            @if (Model.SavedQueries.Count > 0)
            {
                <span class="scdb-tab-count">(@Model.SavedQueries.Count)</span>
            }
            </span>
            <button type="button" class="scdb-panel-tab__dock-btn" data-action="toggle-panel-dock" data-panel="saved"
                    title="Toggle panel" aria-label="Toggle panel">
                <span class="scdb-sidebar__chevron">▸</span>
            </button>
        </button>
        <button class="scdb-panel-tab" id="ptab-history"
                data-action="switch-panel" data-panel="history" role="tab">
            <span>History
            @if (Model.QueryHistory.Count > 0)
            {
                <span class="scdb-tab-count">(@Model.QueryHistory.Count)</span>
            }
            </span>
            <button type="button" class="scdb-panel-tab__dock-btn" data-action="toggle-panel-dock" data-panel="history"
                    title="Toggle panel" aria-label="Toggle panel">
                <span class="scdb-sidebar__chevron">▸</span>
            </button>
        </button>
    </div>

    <div class="scdb-panel-body" id="ppane-connect">
        @if (!Model.IsConnected)
        {
            @if (Model.RecentConnections.Count > 0)
            {
                <div class="scdb-connection-panel scdb-mb-10">
                    <div class="scdb-connection-panel__title">Recent</div>
                    @foreach (var profile in Model.RecentConnections)
                    {
                        <form method="post" asp-page-handler="LoadProfile"
                              asp-route-name="@profile.Name"
                              asp-route-target="@profile.DisplayTarget"
                              class="scdb-mb-4">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="scdb-btn scdb-btn--secondary scdb-btn-w-100-gap-6"
                                    title="@profile.DisplayTarget">
                                <span class="scdb-btn__icon">⬡</span>
                                <span class="scdb-truncate">@profile.Name</span>
                                <span class="scdb-muted scdb-text-xs scdb-ws-nowrap">@profile.DisplayTarget</span>
                            </button>
                        </form>
                    }
                </div>
            }

            <form method="post" asp-page-handler="Connect"
                  id="form-connect"
                  class="scdb-connection-panel">
                @Html.AntiForgeryToken()
                <div class="scdb-connection-panel__title">New Connection</div>

                <div class="scdb-form-group">
                    <label class="scdb-label" asp-for="Connection.Name">Connection name</label>
                    <input class="scdb-input" asp-for="Connection.Name" placeholder="My database" />
                </div>

                <div class="scdb-form-group">
                    <label class="scdb-label">Mode</label>
                    <div class="scdb-form-radio-group">
                        <label class="scdb-form-radio-label">
                            <input type="radio" asp-for="Connection.ConnectionMode" value="Local"
                                   id="radio-mode-local" />
                            Local
                        </label>
                        <label class="scdb-form-radio-label">
                            <input type="radio" asp-for="Connection.ConnectionMode" value="Server"
                                   id="radio-mode-server" />
                            Server
                        </label>
                    </div>
                </div>

                <div id="scdb-local-fields">
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.LocalDatabasePath">Database path</label>
                        <input class="scdb-input" asp-for="Connection.LocalDatabasePath"
                               placeholder="C:\data\mydb" />
                        <span asp-validation-for="Connection.LocalDatabasePath"
                              class="scdb-validation-message"></span>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.LocalStorageMode">Storage mode</label>
                        <select class="scdb-select" asp-for="Connection.LocalStorageMode">
                            <option value="Directory">Directory</option>
                            <option value="SingleFile">Single File</option>
                        </select>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-form-checkbox-label">
                            <input type="checkbox" asp-for="Connection.LocalReadOnly" />
                            Open read-only
                        </label>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.Password">Password</label>
                        <input class="scdb-input" asp-for="Connection.Password" type="password"
                               placeholder="Database password" />
                        <span asp-validation-for="Connection.Password" class="scdb-validation-message"></span>
                    </div>
                </div>

                <div id="scdb-server-fields" hidden>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.ServerHost">Host</label>
                        <input class="scdb-input" asp-for="Connection.ServerHost"
                               placeholder="localhost" />
                        <span asp-validation-for="Connection.ServerHost"
                              class="scdb-validation-message"></span>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.ServerPort">Port</label>
                        <input class="scdb-input scdb-mono" asp-for="Connection.ServerPort"
                               type="number" min="1" max="65535" />
                        <span asp-validation-for="Connection.ServerPort"
                              class="scdb-validation-message"></span>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.ServerDatabase">Database</label>
                        <input class="scdb-input" asp-for="Connection.ServerDatabase"
                               placeholder="master" />
                        <span asp-validation-for="Connection.ServerDatabase"
                              class="scdb-validation-message"></span>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-label" asp-for="Connection.ServerUsername">Username</label>
                        <input class="scdb-input" asp-for="Connection.ServerUsername"
                               placeholder="anonymous" />
                        <span asp-validation-for="Connection.ServerUsername"
                              class="scdb-validation-message"></span>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-form-checkbox-label">
                            <input type="checkbox" asp-for="Connection.ServerUseSsl" />
                            Use TLS/SSL
                        </label>
                    </div>
                    <div class="scdb-form-group">
                        <label class="scdb-form-checkbox-label">
                            <input type="checkbox" asp-for="Connection.ServerPreferHttp3" />
                            Prefer HTTP/3 (gRPC)
                        </label>
                    </div>
                </div>

                <button type="submit" class="scdb-btn scdb-btn--primary scdb-btn--w-100 scdb-mt-4">
                    Connect to Existing
                </button>
            </form>

            <div class="scdb-connection-panel scdb-mt-4">
                <div class="scdb-connection-panel__title">New Database</div>
                <p class="scdb-text-muted scdb-text-12">Create a new local SharpCoreDB database and connect to it.</p>
                <button type="button" class="scdb-btn scdb-btn--secondary scdb-btn--w-100" data-action="open-create-db">
                    + Create &amp; Connect
                </button>
            </div>
        }
        else
        {
            <div class="scdb-connection-panel">
                <div class="scdb-connection-panel__title">Active Session</div>

                <dl class="scdb-session-dl">
                    <dt>Name</dt>
                    <dd class="scdb-mono">@Model.ActiveSession!.Name</dd>
                    <dt>Mode</dt>
                    <dd>@Model.ActiveSession.ConnectionMode</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveSession.LocalDatabasePath))
                    {
                        <dt>Path</dt>
                        <dd class="scdb-mono scdb-truncate" title="@Model.ActiveSession.LocalDatabasePath">
                            @Model.ActiveSession.LocalDatabasePath
                        </dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveSession.ServerHost))
                    {
                        <dt>Host</dt>
                        <dd class="scdb-mono">@Model.ActiveSession.ServerHost:@Model.ActiveSession.ServerPort</dd>
                        <dt>Database</dt>
                        <dd class="scdb-mono">@Model.ActiveSession.ServerDatabase</dd>
                    }
                </dl>

                @if (Model.IsTransactionActive)
                {
                    <div class="scdb-alert scdb-alert--warn scdb-mt-10">
                        <span>⚡</span>
                        <span>Transaction active — @Model.ActiveTransaction!.ConnectionMode</span>
                    </div>
                }

                <form method="post" asp-page-handler="Disconnect" class="scdb-mt-12">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="scdb-btn scdb-btn--danger scdb-btn-w-100">
                        Disconnect
                    </button>
                </form>
            </div>
        }
    </div>

    <div class="scdb-panel-body scdb-hidden" id="ppane-saved">
        <div class="scdb-connection-panel">
            <div class="scdb-connection-panel__title">
                Saved Queries
            </div>

            @if (Model.SavedQueries.Count == 0)
            {
                <p class="scdb-text-muted scdb-text-12">No saved queries yet.</p>
            }
            else
            {
                @foreach (var sq in Model.SavedQueries)
                {
                    <div class="scdb-saved-query">
                        <form method="post" asp-page-handler="LoadSavedQuery"
                              asp-route-queryId="@sq.Id" class="scdb-form-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="scdb-btn scdb-btn--secondary scdb-saved-query__load"
                                    title="Load: @sq.Sql">
                                @sq.Name
                            </button>
                        </form>
                        <form method="post" asp-page-handler="DeleteSavedQuery"
                              asp-route-queryId="@sq.Id" class="scdb-form-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="scdb-btn scdb-btn--danger scdb-saved-query__delete"
                                    title="Delete saved query" aria-label="Delete @sq.Name">✕</button>
                        </form>
                    </div>
                }
            }

            <div class="scdb-panel-section">
                <div class="scdb-panel-section__title">Snippets</div>
                <div class="scdb-snippet-browser scdb-mt-8" id="scdb-snippet-browser">
                    <p class="scdb-text-muted scdb-text-12">No snippets saved.</p>
                </div>
                <button type="button" class="scdb-btn scdb-btn--secondary scdb-btn-w-100 scdb-mt-8" id="btn-add-snippet"
                        data-action="open-snippet-dialog">
                    + Add Snippet
                </button>
            </div>
        </div>
    </div>

    <div class="scdb-panel-body scdb-hidden" id="ppane-history">
        <div class="scdb-connection-panel">
            <div class="scdb-panel-header">
                <span>Query History</span>
                @if (Model.QueryHistory.Count > 0)
                {
                    <form method="post" asp-page-handler="ClearHistory" class="scdb-form-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="scdb-btn scdb-btn--danger scdb-btn--compact">Clear</button>
                    </form>
                }
            </div>

            @if (Model.QueryHistory.Count == 0)
            {
                <p class="scdb-text-muted scdb-text-12">No history yet.</p>
            }
            else
            {
                @foreach (var h in Model.QueryHistory)
                {
                    <button type="button" class="scdb-history-item @(h.Succeeded ? "" : "scdb-history-item--error")"
                         title="@h.SqlPreview"
                         data-action="load-history"
                         data-sql="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(h.SqlPreview))">
                        <div class="scdb-history-item__sql scdb-mono scdb-truncate">@h.SqlPreview</div>
                        <div class="scdb-history-item__meta scdb-muted">
                            <span>@h.ExecutedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                            <span>@h.TargetDisplay</span>
                            @if (!h.Succeeded)
                            {
                                <span class="scdb-text-error">✕ failed</span>
                            }
                        </div>
                    </button>
                }
            }
        </div>
    </div>
</div>

<div id="scdb-command-palette" class="scdb-overlay scdb-hidden" aria-hidden="true">
    <div class="scdb-command-palette" role="dialog" aria-label="Command palette" aria-modal="true">
        <input type="text" id="scdb-command-input" class="scdb-input scdb-command-palette__input" placeholder="Type a command..." autocomplete="off" />
        <ul id="scdb-command-list" class="scdb-command-palette__list" role="listbox" aria-label="Commands"></ul>
        <div class="scdb-command-palette__hint">Enter: run · Esc: close · ↑↓: navigate</div>
    </div>
</div>

<div id="scdb-explorer-contextmenu" class="scdb-contextmenu scdb-hidden" role="menu" aria-label="Table actions">
    <button type="button" class="scdb-contextmenu__item" data-action="ctx-new">New Query</button>
    <button type="button" class="scdb-contextmenu__item" data-action="ctx-top">Select Top 100</button>
    <button type="button" class="scdb-contextmenu__item" data-action="ctx-count">Count Rows</button>
</div>

<dialog id="scdb-create-db-dialog" class="scdb-snippet-dialog">
    <form method="post" asp-page-handler="Connect" id="form-create-db">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Connection.ConnectionMode" value="Local" />
        <div class="scdb-snippet-dialog__header">
            <h3 class="scdb-no-margin">Create New Database</h3>
            <button type="button" class="scdb-snippet-dialog__close" data-action="close-create-db" aria-label="Close">✕</button>
        </div>
        <div class="scdb-snippet-dialog__body">
            <div class="scdb-form-group">
                <label class="scdb-label" for="create-db-name">Connection name</label>
                <input type="text" class="scdb-input" id="create-db-name" name="Connection.Name" placeholder="My New Database" />
            </div>
            <div class="scdb-form-group">
                <label class="scdb-label" for="create-db-path">Database path <span class="scdb-required">*</span></label>
                <input type="text" class="scdb-input" id="create-db-path" name="Connection.LocalDatabasePath" placeholder="C:\data\mynewdb" />
                <span class="scdb-validation-message" id="create-db-path-error"></span>
                <small class="scdb-text-muted scdb-text-12">The folder will be created if it does not exist.</small>
            </div>
            <div class="scdb-form-group">
                <label class="scdb-label" for="create-db-mode">Storage mode</label>
                <select class="scdb-select" id="create-db-mode" name="Connection.LocalStorageMode">
                    <option value="Directory">Directory</option>
                    <option value="SingleFile">Single File</option>
                </select>
            </div>
            <div class="scdb-form-group">
                <label class="scdb-label" for="create-db-password">Password <span class="scdb-required">*</span></label>
                <input type="password" class="scdb-input" id="create-db-password" name="Connection.Password" placeholder="Choose a database password" />
                <span class="scdb-validation-message" id="create-db-password-error"></span>
                <small class="scdb-text-muted scdb-text-12">Required — used to encrypt and open the database.</small>
            </div>
        </div>
        <div class="scdb-snippet-dialog__footer">
            <button type="button" class="scdb-btn scdb-btn--secondary" data-action="close-create-db">Cancel</button>
            <button type="submit" class="scdb-btn scdb-btn--primary">Create &amp; Connect</button>
        </div>
    </form>
</dialog>

<dialog id="scdb-snippet-dialog" class="scdb-snippet-dialog">
    <div class="scdb-snippet-dialog__header">
        <h3 class="scdb-no-margin">Add SQL Snippet</h3>
        <button type="button" class="scdb-snippet-dialog__close" data-action="close-snippet-dialog" aria-label="Close">✕</button>
    </div>
    <div class="scdb-snippet-dialog__body">
        <div class="scdb-form-group">
            <label class="scdb-label" for="snippet-name">Snippet Name</label>
            <input type="text" class="scdb-input" id="snippet-name" placeholder="e.g., Select All Users" />
        </div>
        <div class="scdb-form-group">
            <label class="scdb-label" for="snippet-category">Category (optional)</label>
            <input type="text" class="scdb-input" id="snippet-category" placeholder="e.g., Common Queries" />
        </div>
        <div class="scdb-form-group">
            <label class="scdb-label" for="snippet-sql">SQL Template</label>
            <textarea class="scdb-input scdb-mono" id="snippet-sql" rows="6" placeholder="SELECT * FROM table WHERE id = 1;"></textarea>
        </div>
    </div>
    <div class="scdb-snippet-dialog__footer">
        <button type="button" class="scdb-btn scdb-btn--secondary" data-action="close-snippet-dialog">Cancel</button>
        <button type="button" class="scdb-btn scdb-btn--primary" data-action="save-snippet">Save Snippet</button>
    </div>
</dialog>

@section Scripts {
    <script src="~/js/webviewer-pro.js" asp-append-version="true"></script>
}

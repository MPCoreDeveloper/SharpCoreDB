@using SafeWebCore.Extensions
@{
    var cspNonce = Context.GetCspNonce();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csp-nonce" content="@cspNonce" />
    <title>@ViewData["Title"] - SharpCoreDB Web Viewer</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <strong>SharpCoreDB Web Viewer</strong>
        <span class="muted">v1.7.0 · Razor Pages</span>
    </header>
    <main>
        @RenderBody()
    </main>
    <script>
        document.documentElement.dataset.cspNonce = "@cspNonce";
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

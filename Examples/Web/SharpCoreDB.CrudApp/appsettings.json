{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SharpCoreDb": {
    "DatabaseFilePath": "App_Data/sharpcore-crud.scdb",
    "EncryptionPassword": "CHANGE-ME-USE-USER-SECRETS",
    "MasterPassword": "CHANGE-ME-USE-USER-SECRETS"
  },
  "SharpCoreIdentity": {
    "Password": {
      "RequiredLength": 8,
      "RequireNonAlphanumeric": true,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "IterationCount": 210000,
      "SaltSize": 16,
      "HashSize": 32,
      "Algorithm": "Sha256"
    },
    "Lockout": {
      "AllowedForNewUsers": true,
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpan": "00:10:00"
    }
  }
}

@{
    ViewData["Title"] = "Home";
}

<div class="p-4 mb-4 bg-light rounded-3">
    <div class="container-fluid py-2">
        <h1 class="display-6">SharpCoreDB CRUD + Identity Demo</h1>
        <p class="lead mb-2">Encrypted single-file <code>.scdb</code> storage with cookie authentication and full product CRUD.</p>
        <p class="mb-0">
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Open Products</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary">Create Account</a>
        </p>
    </div>
</div>

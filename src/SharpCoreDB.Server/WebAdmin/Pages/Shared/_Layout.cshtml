<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – SharpCoreDB Admin</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; font-size: 14px; background: #f4f5f7; color: #172b4d; min-height: 100vh; }
        a { color: #0052cc; text-decoration: none; }
        a:hover { text-decoration: underline; }
        /* Nav */
        nav { background: #172b4d; color: #fff; padding: 0 24px; display: flex; align-items: center; height: 48px; gap: 24px; }
        nav .brand { font-weight: 700; font-size: 15px; color: #fff; white-space: nowrap; }
        nav .brand span { color: #4c9aff; }
        nav a.nav-link { color: #b3d4f5; font-size: 13px; padding: 4px 0; border-bottom: 2px solid transparent; }
        nav a.nav-link:hover, nav a.nav-link.active { color: #fff; border-bottom-color: #4c9aff; text-decoration: none; }
        nav .spacer { flex: 1; }
        nav .user-info { font-size: 12px; color: #b3d4f5; }
        /* Layout */
        .page-wrapper { max-width: 1100px; margin: 0 auto; padding: 28px 24px; }
        h1 { font-size: 22px; font-weight: 700; margin-bottom: 20px; }
        h2 { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
        /* Cards */
        .card { background: #fff; border-radius: 6px; box-shadow: 0 1px 3px rgba(0,0,0,.12); padding: 20px; margin-bottom: 20px; }
        .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px; }
        .stat-card { background: #fff; border-radius: 6px; box-shadow: 0 1px 3px rgba(0,0,0,.12); padding: 16px 20px; }
        .stat-card .stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: .6px; color: #6b778c; margin-bottom: 4px; }
        .stat-card .stat-value { font-size: 24px; font-weight: 700; color: #172b4d; }
        .stat-card .stat-sub { font-size: 12px; color: #6b778c; margin-top: 2px; }
        /* Badge */
        .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
        .badge-green { background: #e3fcef; color: #006644; }
        .badge-red { background: #ffebe6; color: #bf2600; }
        .badge-yellow { background: #fffae6; color: #974f0c; }
        .badge-gray { background: #f4f5f7; color: #5e6c84; }
        .badge-blue { background: #deebff; color: #0747a6; }
        /* Tables */
        table { width: 100%; border-collapse: collapse; font-size: 13px; }
        th { text-align: left; padding: 8px 12px; background: #f4f5f7; font-weight: 600; border-bottom: 2px solid #dfe1e6; }
        td { padding: 8px 12px; border-bottom: 1px solid #ebecf0; vertical-align: top; word-break: break-word; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f8f9fb; }
        /* Forms */
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #5e6c84; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 8px 10px; border: 1px solid #dfe1e6; border-radius: 4px; font-size: 14px; transition: border-color .15s; outline: none; }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: #4c9aff; box-shadow: 0 0 0 2px rgba(76,154,255,.2); }
        .form-group textarea { font-family: "Cascadia Code", Consolas, "Courier New", monospace; resize: vertical; min-height: 100px; }
        /* Buttons */
        .btn { display: inline-block; padding: 7px 16px; border-radius: 4px; font-size: 14px; font-weight: 500; border: none; cursor: pointer; transition: background .15s; }
        .btn-primary { background: #0052cc; color: #fff; }
        .btn-primary:hover { background: #0747a6; }
        .btn-danger { background: #de350b; color: #fff; }
        .btn-danger:hover { background: #bf2600; }
        .btn-ghost { background: transparent; color: #0052cc; border: 1px solid #0052cc; }
        .btn-ghost:hover { background: #deebff; }
        /* Alert */
        .alert { padding: 10px 14px; border-radius: 4px; font-size: 13px; margin-bottom: 16px; }
        .alert-error { background: #ffebe6; color: #bf2600; border-left: 3px solid #de350b; }
        .alert-warning { background: #fffae6; color: #974f0c; border-left: 3px solid #f6a623; }
        .alert-success { background: #e3fcef; color: #006644; border-left: 3px solid #00875a; }
        /* Query result */
        .query-result-table { overflow-x: auto; }
        .mono { font-family: "Cascadia Code", Consolas, "Courier New", monospace; font-size: 12px; }
        /* Login */
        .login-center { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #172b4d; }
        .login-box { background: #fff; border-radius: 8px; padding: 40px; width: 360px; box-shadow: 0 4px 24px rgba(0,0,0,.3); }
        .login-box h1 { font-size: 20px; margin-bottom: 6px; }
        .login-box .sub { font-size: 12px; color: #6b778c; margin-bottom: 24px; }
    </style>
</head>
<body>
@if (Context.User.Identity?.IsAuthenticated == true)
{
    <nav>
        <span class="brand">SharpCoreDB <span>Admin</span></span>
        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/admin") && Context.Request.Path == "/admin" ? "active" : "")"
           href="/admin">Dashboard</a>
        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/admin/databases") ? "active" : "")"
           href="/admin/databases">Databases</a>
        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/admin/query") ? "active" : "")"
           href="/admin/query">Query</a>
        <a class="nav-link @(Context.Request.Path.StartsWithSegments("/admin/metrics") ? "active" : "")"
           href="/admin/metrics">Metrics</a>
        <span class="spacer"></span>
        <span class="user-info">@Context.User.Identity.Name</span>
        <form method="post" action="/admin/logout" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-ghost" style="font-size:12px;padding:4px 10px;color:#b3d4f5;border-color:#b3d4f5;">Sign out</button>
        </form>
    </nav>
}

@RenderBody()

</body>
</html>
